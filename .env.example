# Backend
APP_ENV=development
APP_VERSION=0.1.0
HOST=0.0.0.0
PORT=8000
FRONTEND_ORIGIN=http://localhost:5173
LOG_LEVEL=INFO

# Safety and limits
MAX_INPUT_CHARACTERS=12000
PROVIDER_TIMEOUT_SECONDS=20
MAX_SEARCH_QUERIES=3
MAX_EVIDENCE_ITEMS=8
MOCK_MODE=true

# LLM provider
OPENAI_API_KEY=
OPENAI_MODEL=

# Optional search provider
TAVILY_API_KEY=

# Optional enrichment
VIRUSTOTAL_API_KEY=

# Frontend
VITE_API_BASE_URL=http://localhost:8000
